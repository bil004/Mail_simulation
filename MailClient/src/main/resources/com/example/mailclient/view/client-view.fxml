<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.text.*?>

<BorderPane prefHeight="600.0" prefWidth="900.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.mailclient.controller.ClientController">

    <top>
        <ToolBar prefHeight="40.0" prefWidth="200.0" BorderPane.alignment="CENTER">
            <items>
                <Button fx:id="btnNewEmail" mnemonicParsing="false" onAction="#onNewEmailButtonClick" text="➕ New" />
                <Separator orientation="VERTICAL" />
                <Button fx:id="btnReply" mnemonicParsing="false" text="↩ Reply" onAction="#onReplyButtonClick"/>
                <Button fx:id="btnDelete" mnemonicParsing="false" style="-fx-text-fill: red;" text="🗑 Delete" onAction="#onDeleteButtonClick"/>
            </items>
        </ToolBar>
    </top>

    <center>
        <SplitPane dividerPositions="0.35" prefHeight="160.0" prefWidth="200.0" BorderPane.alignment="CENTER">
            <items>
                <ListView fx:id="emailListView" prefHeight="200.0" prefWidth="200.0" />

                <VBox spacing="10.0">
                    <padding>
                        <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
                    </padding>
                    <children>
                        <Label fx:id="lblSubject" text="Email Subject">
                            <font>
                                <Font name="System Bold" size="18.0" />
                            </font>
                        </Label>
                        <GridPane vgap="5.0">
                            <columnConstraints>
                                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="50.0" />
                                <ColumnConstraints hgrow="ALWAYS" minWidth="10.0" />
                            </columnConstraints>
                            <rowConstraints>
                                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                            </rowConstraints>
                            <children>
                                <Label text="Da:" textFill="#7c7c7c" />
                                <Label fx:id="lblFrom" text="-" GridPane.columnIndex="1" />
                                <Label text="Data:" textFill="#7c7c7c" GridPane.rowIndex="1" />
                                <Label fx:id="lblDate" text="-" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                            </children>
                        </GridPane>
                        <Separator prefWidth="200.0" />
                        <TextArea fx:id="messageBody" editable="false" prefHeight="200.0" prefWidth="200.0" wrapText="true" VBox.vgrow="ALWAYS" />
                    </children>
                </VBox>
            </items>
        </SplitPane>
    </center>

    <bottom>
        <HBox alignment="CENTER_RIGHT" prefHeight="25.0" spacing="8.0" style="-fx-background-color: #f0f0f0; -fx-border-color: #dcdcdc; -fx-border-width: 1 0 0 0;">
            <padding>
                <Insets left="10.0" right="10.0" />
            </padding>
            <children>
                <Circle fx:id="serverStatusLed" fill="RED" radius="6.0" stroke="BLACK" strokeType="INSIDE" strokeWidth="0.0" />

                <Label fx:id="statusLabel" text="Offline" textFill="#616161">
                    <font>
                        <Font size="11.0" />
                    </font>
                </Label>
            </children>
        </HBox>
    </bottom>
</BorderPane>
