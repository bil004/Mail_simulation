<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox prefHeight="450.0" prefWidth="500.0" spacing="10.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.mailclient.controller.ComposeController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
    <children>
        <Label text="New message">
            <font>
                <Font name="System Bold" size="18.0" />
            </font>
        </Label>

        <VBox spacing="5.0">
            <children>
                <Label text="To: (Insert , for multiple receivers)" />
                <TextField fx:id="txtTo" promptText="example@gmail.com, example2@hotmail.com" />
            </children>
        </VBox>

        <VBox spacing="5.0">
            <children>
                <Label text="Subject: " />
                <TextField fx:id="txtSubject" promptText="Insert subject here..." />
            </children>
        </VBox>

        <VBox spacing="5.0" VBox.vgrow="ALWAYS">
            <children>
                <Label text="Message: " />
                <TextArea fx:id="txtMessage" prefHeight="200.0" promptText="Insert your text here..." wrapText="true" VBox.vgrow="ALWAYS" />
            </children>
        </VBox>

        <HBox alignment="CENTER_RIGHT" spacing="10.0">
            <children>
                <Button fx:id="btnCancel" mnemonicParsing="false" onAction="#onCancelButton" prefWidth="80.0" text="Undo" />
                <Button fx:id="btnSend" defaultButton="true" mnemonicParsing="false" onAction="#onSendClick" prefWidth="80.0" style="-fx-background-color: #2196F3; -fx-text-fill: white;" text="Send" />
            </children>
            <VBox.margin>
                <Insets top="10.0" />
            </VBox.margin>
        </HBox>
    </children>
</VBox>
