<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.mailserver.controller.ServerController" spacing="10" style="-fx-padding: 15;">

    <Label text="Mail Server Log Monitor" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

    <TableView fx:id="logTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colTime" text="Time" prefWidth="100"/>
            <TableColumn fx:id="colType" text="Type" prefWidth="120"/>
            <TableColumn fx:id="colDesc" text="Description" prefWidth="400"/>
        </columns>
    </TableView>
</VBox>
